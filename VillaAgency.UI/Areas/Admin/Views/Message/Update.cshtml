@model UpdateMessageDto

@{
    ViewData["Title"] = "Message Details";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/custom_admin_message.css" />

<div class="container-fluid">
    <div class="create-message-wrapper">
        <div class="create-message-container">

            <div class="d-flex justify-content-between align-items-center mb-3 px-1">

                <a asp-area="Admin"
                   asp-controller="Message"
                   asp-action="Index"
                   class="btn btn-sm btn-link p-0 d-flex align-items-center gap-1 text-decoration-none"
                   style="font-size:.85rem;font-weight:600;color:var(--text-sub);">
                    <i class="bi bi-arrow-left"></i>
                    Back to Inbox
                </a>

                <div class="d-flex gap-2">

                    <a asp-area="Admin"
                       asp-controller="Message"
                       asp-action="MarkAsRead"
                       asp-route-id="@Model.Id"
                       class="btn btn-sm btn-success d-flex align-items-center gap-1 px-3 fw-semibold shadow-sm">
                        <i class="bi bi-envelope-open-fill"></i>
                        Mark as Read
                    </a>

                    <a asp-area="Admin"
                       asp-controller="Message"
                       asp-action="MarkAsNotRead"
                       asp-route-id="@Model.Id"
                       class="btn btn-sm btn-warning text-dark d-flex align-items-center gap-1 px-3 fw-semibold shadow-sm">
                        <i class="bi bi-envelope-fill"></i>
                        Mark as Unread
                    </a>

                    <a asp-area="Admin"
                       asp-controller="Message"
                       asp-action="Delete"
                       asp-route-id="@Model.Id"
                       class="btn btn-sm btn-danger d-flex align-items-center gap-1 px-3 fw-semibold shadow-sm"
                       onclick="deleteMessage('@Model.Id')">
                        <i class="bi bi-trash3-fill"></i>
                        Move to Trash
                    </a>

                </div>

            </div>

            <div class="custom-card border shadow-sm rounded-3 overflow-hidden">

                <div class="card-form-header border-bottom py-3 px-4">

                    <h4 class="m-0 fw-bold">
                        <i class="bi bi-envelope-paper text-primary me-2"></i>
                        Message Reader
                    </h4>

                    <p class="m-0 mt-1 small">
                        Review the incoming inquiry data details below.
                    </p>

                </div>

                <div class="card-form-body">

                    <div class="form-grid-layout">

                        <div class="form-left-side">

                            <div class="form-group-custom">

                                <label>Full Name</label>

                                <div class="input-icon-wrapper">

                                    <input asp-for="Name"
                                           class="form-control message-readonly"
                                           readonly />

                                    <i class="fas fa-user"></i>

                                </div>

                            </div>

                            <div class="form-group-custom">

                                <label>Email Address</label>

                                <div class="input-icon-wrapper">

                                    <input asp-for="Email"
                                           class="form-control message-readonly"
                                           readonly />

                                    <i class="fas fa-envelope"></i>

                                </div>

                            </div>

                            <div class="form-group-custom">

                                <label>Subject</label>

                                <div class="input-icon-wrapper">

                                    <input asp-for="Subject"
                                           class="form-control message-readonly fw-semibold"
                                           readonly />

                                    <i class="fas fa-heading"></i>

                                </div>

                            </div>

                        </div>

                        <div class="form-right-side">

                            <div class="form-group-custom fill-height">

                                <label>Message Content</label>

                                <div class="input-icon-wrapper textarea-wrapper">

                                    <textarea asp-for="Content"
                                              class="form-control message-readonly"
                                              readonly></textarea>

                                    <i class="fas fa-comment-alt"></i>

                                </div>

                            </div>

                        </div>

                    </div>

                    <div class="form-action-footer">

                        <a asp-area="Admin"
                           asp-controller="Message"
                           asp-action="Index"
                           class="btn btn-primary px-4 fw-semibold shadow-sm">

                            <i class="bi bi-check-lg me-1"></i>
                            Done

                        </a>

                    </div>

                </div>

            </div>

        </div>
    </div>
</div>

<script src="~/js/custom_admin_message.js"></script>