@model UpdateMessageDto
@{
    ViewData["Title"] = "Update";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/custom_admin_message.css" />

<div class="container-fluid">
    <div class="create-message-wrapper">
        <div class="create-message-container">

            <div class="mb-3 pl-1">
                <a asp-area="Admin" asp-controller="Message" asp-action="Index" class="btn btn-sm btn-link p-0" style="color: var(--btn-primary); text-decoration: none; font-size: 0.85rem; font-weight: 600;">
                    Back to Inbox
                </a>
            </div>

            <div class="custom-card">
                <div class="card-form-header">
                    <h4 class="m-0 font-weight-bold" style="color: var(--text-main); font-size: 1.2rem;">
                        Update Message Details
                    </h4>
                    <p class="m-0 mt-1 small" style="color: var(--text-sub);">Modify the values below to update the existing message record.</p>
                </div>

                <div class="card-form-body">
                    <form method="post" asp-area="Admin" asp-controller="Message" asp-action="Update">

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" name="activeTab" value="@ViewBag.ActiveTab" />

                        <div class="form-grid-layout">
                            <div class="form-left-side">
                                <div class="form-group-custom">
                                    <label asp-for="Name">Full Name</label>
                                    <div class="input-icon-wrapper">
                                        <input asp-for="Name" class="form-input-custom" placeholder="John Doe" autocomplete="off" />
                                        <i class="fas fa-user"></i>
                                    </div>
                                    <span asp-validation-for="Name" class="text-danger small mt-1"></span>
                                </div>

                                <div class="form-group-custom">
                                    <label asp-for="Email">Email Address</label>
                                    <div class="input-icon-wrapper">
                                        <input asp-for="Email" class="form-input-custom" placeholder="johndoe@example.com" autocomplete="off" />
                                        <i class="fas fa-envelope"></i>
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger small mt-1"></span>
                                </div>

                                <div class="form-group-custom">
                                    <label asp-for="Subject">Subject</label>
                                    <div class="input-icon-wrapper">
                                        <input asp-for="Subject" class="form-input-custom" placeholder="Inquiry about..." autocomplete="off" />
                                        <i class="fas fa-heading"></i>
                                    </div>
                                    <span asp-validation-for="Subject" class="text-danger small mt-1"></span>
                                </div>
                            </div>

                            <div class="form-right-side">
                                <div class="form-group-custom fill-height">
                                    <label asp-for="Content">Message Content</label>
                                    <div class="input-icon-wrapper textarea-wrapper">
                                        <textarea asp-for="Content" class="form-input-custom textarea-custom" placeholder="Type your detailed message here..."></textarea>
                                        <i class="fas fa-comment-alt"></i>
                                    </div>
                                    <span asp-validation-for="Content" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-action-footer">
                            <a asp-area="Admin" asp-controller="Message" asp-action="Index" class="btn-cancel-message" style="text-decoration: none;">Cancel</a>
                            <button type="submit" class="btn-submit-message">
                                <i class="fas fa-save mr-1"></i> Save Changes
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>