@model MessageIndexViewModel
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/custom_admin_message.css" /> 

<div class="container-fluid py-4">

    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-3 border-bottom border-secondary-subtle position-relative px-0 mb-4">
        <div class="d-flex align-items-center gap-2">
            <span class="bg-primary rounded-pill" style="width: 4px; height: 18px;"></span>
            <div>
                <h5 class="m-0 fw-bold text-body" style="letter-spacing: 0.6px; font-size: 0.95rem;">
                    MESSAGE MANAGEMENT PORTAL
                </h5>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-3">
                    <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist" aria-orientation="vertical">

                        <a asp-action="Index" asp-route-activeTab="all-messages" asp-route-page="1" class="nav-link @(ViewBag.ActiveTab == "all-messages" ? "active" : "") text-start d-flex align-items-center mb-2 py-2 px-3" style="text-decoration: none;">
                            <i class="bi bi-envelope-fill me-2"></i> All Messages
                            <span class="badge bg-warning ms-auto fw-normal">@Model.AllCount</span>
                        </a>

                        <a asp-action="Index" asp-route-activeTab="unread-messages" asp-route-page="1" class="nav-link @(ViewBag.ActiveTab == "unread-messages" ? "active" : "") text-start d-flex align-items-center mb-2 py-2 px-3" style="text-decoration: none;">
                            <i class="bi bi-envelope-open me-2"></i> Unread Messages
                            <span class="badge bg-danger ms-auto fw-normal">@Model.UnreadCount</span>
                        </a>

                        <a asp-action="Index" asp-route-activeTab="deleted-messages" asp-route-page="1" class="nav-link @(ViewBag.ActiveTab == "deleted-messages" ? "active" : "") text-start d-flex align-items-center mb-3 py-2 px-3" style="text-decoration: none;">
                            <i class="bi bi-trash3-fill me-2"></i> Deleted Messages
                            <span class="badge bg-secondary text-white ms-auto fw-normal">@Model.DeletedCount</span>
                        </a>

                    </div>

                    <hr class="my-3 opacity-25" />

                    <div class="bg-light-subtle p-3 rounded-3 border text-center">
                        <h6 class="fw-bold mb-2 text-primary" style="font-size: 0.9rem;">Log Offline Message</h6>
                        <p class="text-muted mb-3" style="font-size: 0.8rem; line-height: 1.4;">Did a customer call or reach out offline? You can manually log their request into the system.</p>
                        <a asp-action="Create" asp-controller="Message" asp-area="Admin" class="btn btn-sm btn-primary w-100 py-2 fw-medium d-flex align-items-center justify-content-center gap-1">
                            <i class="bi bi-plus-circle"></i> Create New Message
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body px-4 py-4">
                    <div class="tab-content" id="v-pills-tabContent">

                        @* --- ALL MESSAGES TAB --- *@
                        <div class="tab-pane fade @(ViewBag.ActiveTab == "all-messages" ? "show active" : "")" id="all-messages" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0" style="font-size: 0.875rem; table-layout: fixed; width: 100%;">
                                    <thead class="table-light text-uppercase fs-7 text-muted" style="letter-spacing: 0.05em;">
                                        <tr>
                                            <th style="width: 14%;" class="text-center">Status</th>
                                            <th style="width: 18%;" class="text-center">Date & Time</th>
                                            <th style="width: 28%;">Sender Info</th>
                                            <th style="width: 25%;" class="text-center">Subject</th>
                                            <th class="text-end" style="width: 15%;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.AllMessages != null && Model.AllMessages.Any())
                                        {
                                            foreach (var item in Model.AllMessages)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="d-flex flex-column align-items-center justify-content-center gap-1" style="min-height: 38px;">
                                                            @if (item.IsRead)
                                                            {
                                                                <span class="text-success fw-semibold d-inline-flex align-items-center gap-1" title="Read" style="font-size: 0.875rem; line-height: 1;">
                                                                    <i class="bi bi-check2-all fs-5" style="line-height: 1; margin-top: -1px;"></i> Read
                                                                </span>
                                                                <a asp-action="MarkAsNotRead" asp-route-id="@item.Id" asp-route-activeTab="all-messages" asp-route-page="@Model.CurrentPage"
                                                                   class="btn btn-sm d-inline-flex align-items-center justify-content-center fw-semibold text-decoration-none"
                                                                   style="font-size: 0.65rem; height: 18px; padding: 0 6px; line-height: 1; background-color: #e2e8f0; color: #475569; border: 1px solid #cbd5e1;">
                                                                    Mark Unread
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <a asp-action="MarkAsRead" asp-route-id="@item.Id" asp-route-activeTab="all-messages" asp-route-page="@Model.CurrentPage"
                                                                   class="btn btn-sm d-inline-flex align-items-center justify-content-center fw-semibold text-decoration-none"
                                                                   style="font-size: 0.72rem; height: 24px; padding: 0 10px; line-height: 1; background-color: #f8d7da; color: #842029; border: 1px solid #f5c2c7;">
                                                                    Mark Read
                                                                </a>
                                                            }
                                                        </div>
                                                    </td>
                                                    <td class="text-secondary text-center" style="font-size: 0.825rem; word-break: break-word;">
                                                        @item.MessageDate.ToString("dd MMM yyyy HH:mm", new System.Globalization.CultureInfo("en-US"))
                                                    </td>
                                                    <td class="text-truncate">
                                                        <div class="fw-semibold text-dark text-truncate" title="@item.Name">@item.Name</div>
                                                        <div class="text-muted text-truncate" style="font-size: 0.8rem;" title="@item.Email">@item.Email</div>
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="d-flex justify-content-center">
                                                            <span class="badge fw-normal px-2 py-1.5 w-100 text-center text-wrap text-clamp-2 subject-clickable"
                                                                  style="background-color: #f3e8ff; color: #6b21a8; border: 1px solid #e9d5ff; letter-spacing: 0.2px; font-size: 0.75rem; max-width: 220px;"
                                                                  title="Click to preview message"
                                                                  data-bs-toggle="modal"
                                                                  data-bs-target="#messagePreviewModal"
                                                                  data-name="@item.Name"
                                                                  data-email="@item.Email"
                                                                  data-subject="@item.Subject"
                                                                  data-content="@item.Content"
                                                                  data-date="@item.MessageDate.ToString("dd MMM yyyy HH:mm")">
                                                                @item.Subject
                                                            </span>
                                                        </div>
                                                    </td>
                                                    <td class="text-end">
                                                        <div class="btn-group shadow-sm rounded" role="group">
                                                            <a asp-action="Update" asp-route-id="@item.Id" asp-route-activeTab="all-messages" asp-route-page="@Model.CurrentPage" class="btn btn-sm btn-outline-secondary px-2" title="Details / Edit">
                                                                <i class="bi bi-eye"></i>
                                                            </a>
                                                            <a asp-action="Delete" asp-route-id="@item.Id" asp-route-activeTab="all-messages" asp-route-page="@Model.CurrentPage"  class="btn btn-sm btn-outline-danger px-2" title="Move to Trash">
                                                                <i class="bi bi-trash3"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center py-5 text-muted">
                                                    <div class="mb-2"><i class="bi bi-envelope text-secondary fs-2"></i></div>
                                                    <p class="mb-0 small">No active messages found.</p>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        @* --- UNREAD MESSAGES TAB --- *@
                        <div class="tab-pane fade @(ViewBag.ActiveTab == "unread-messages" ? "show active" : "")" id="unread-messages" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0" style="font-size: 0.875rem; table-layout: fixed; width: 100%;">
                                    <thead class="table-light text-uppercase fs-7 text-muted" style="letter-spacing: 0.05em;">
                                        <tr>
                                            <th style="width: 14%;" class="text-center">Status</th>
                                            <th style="width: 18%;" class="text-center">Date & Time</th>
                                            <th style="width: 28%;">Sender Info</th>
                                            <th style="width: 25%;" class="text-center">Subject</th>
                                            <th class="text-end" style="width: 15%;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.UnreadMessages != null && Model.UnreadMessages.Any())
                                        {
                                            foreach (var item in Model.UnreadMessages)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center justify-content-center" style="height: 38px;">
                                                            <a asp-action="MarkAsRead" asp-route-id="@item.Id" asp-route-activeTab="unread-messages" asp-route-page="@Model.CurrentPage"
                                                               class="btn btn-sm d-inline-flex align-items-center justify-content-center fw-semibold text-decoration-none"
                                                               style="font-size: 0.72rem; height: 24px; padding: 0 10px; line-height: 1; background-color: #f8d7da; color: #842029; border: 1px solid #f5c2c7;">
                                                                Mark Read
                                                            </a>
                                                        </div>
                                                    </td>
                                                    <td class="text-secondary text-center" style="font-size: 0.825rem; word-break: break-word;">
                                                        @item.MessageDate.ToString("dd MMM yyyy HH:mm", new System.Globalization.CultureInfo("en-US"))
                                                    </td>
                                                    <td class="text-truncate">
                                                        <div class="fw-semibold text-dark text-truncate" title="@item.Name">@item.Name</div>
                                                        <div class="text-muted text-truncate" style="font-size: 0.8rem;" title="@item.Email">@item.Email</div>
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="d-flex justify-content-center">
                                                            <span class="badge fw-normal px-2 py-1.5 w-100 text-center text-wrap text-clamp-2 subject-clickable"
                                                                  style="background-color: #f3e8ff; color: #6b21a8; border: 1px solid #e9d5ff; letter-spacing: 0.2px; font-size: 0.75rem; max-width: 220px;"
                                                                  title="Click to preview message"
                                                                  data-bs-toggle="modal"
                                                                  data-bs-target="#messagePreviewModal"
                                                                  data-name="@item.Name"
                                                                  data-email="@item.Email"
                                                                  data-subject="@item.Subject"
                                                                  data-content="@item.Content"
                                                                  data-date="@item.MessageDate.ToString("dd MMM yyyy HH:mm")">
                                                                @item.Subject
                                                            </span>
                                                        </div>
                                                    </td>
                                                    <td class="text-end">
                                                        <div class="btn-group shadow-sm rounded" role="group">
                                                            <a asp-action="Update" asp-route-id="@item.Id" asp-route-activeTab="unread-messages" asp-route-page="@Model.CurrentPage" class="btn btn-sm btn-outline-secondary px-2">
                                                                <i class="bi bi-eye"></i>
                                                            </a>
                                                            <a asp-action="Delete" asp-route-id="@item.Id" asp-route-activeTab="unread-messages" asp-route-page="@Model.CurrentPage"  class="btn btn-sm btn-outline-danger px-2">
                                                                <i class="bi bi-trash3"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center py-5 text-muted">
                                                    <div class="mb-2"><i class="bi bi-envelope-open text-secondary fs-2"></i></div>
                                                    <p class="mb-0 small">No unread messages found.</p>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        @* --- DELETED MESSAGES (TRASH) TAB --- *@
                        <div class="tab-pane fade @(ViewBag.ActiveTab == "deleted-messages" ? "show active" : "")" id="deleted-messages" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0" style="font-size: 0.875rem; table-layout: fixed; width: 100%;">
                                    <thead class="table-light text-uppercase fs-7 text-muted" style="letter-spacing: 0.05em;">
                                        <tr>
                                            <th style="width: 14%;" class="text-center">Status</th>
                                            <th style="width: 18%;" class="text-center">Date & Time</th>
                                            <th style="width: 28%;">Sender Info</th>
                                            <th style="width: 25%;" class="text-center">Subject</th>
                                            <th class="text-end" style="width: 15%;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.DeletedMessages != null && Model.DeletedMessages.Any())
                                        {
                                            foreach (var item in Model.DeletedMessages)
                                            {
                                                <tr class="opacity-75">
                                                    <td>
                                                        <div class="d-flex align-items-center justify-content-center" style="height: 38px;">
                                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle fw-normal">Deleted</span>
                                                        </div>
                                                    </td>
                                                    <td class="text-secondary text-center" style="font-size: 0.825rem; word-break: break-word;">
                                                        @item.MessageDate.ToString("dd MMM yyyy HH:mm", new System.Globalization.CultureInfo("en-US"))
                                                    </td>
                                                    <td class="text-truncate">
                                                        <div class="fw-semibold text-dark text-truncate text-decoration-line-through" title="@item.Name">@item.Name</div>
                                                        <div class="text-muted text-truncate" style="font-size: 0.8rem;" title="@item.Email">@item.Email</div>
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="d-flex justify-content-center">
                                                            <span class="badge fw-normal px-2 py-1.5 w-100 text-center text-wrap text-clamp-2 subject-clickable"
                                                                  style="background-color: #f3e8ff; color: #6b21a8; border: 1px solid #e9d5ff; letter-spacing: 0.2px; font-size: 0.75rem; max-width: 220px;"
                                                                  title="Click to preview message"
                                                                  data-bs-toggle="modal"
                                                                  data-bs-target="#messagePreviewModal"
                                                                  data-name="@item.Name"
                                                                  data-email="@item.Email"
                                                                  data-subject="@item.Subject"
                                                                  data-content="@item.Content"
                                                                  data-date="@item.MessageDate.ToString("dd MMM yyyy HH:mm")">
                                                                @item.Subject
                                                            </span>
                                                        </div>
                                                    </td>
                                                    <td class="text-end">
                                                        <div class="btn-group shadow-sm rounded" role="group">
                                                            <a asp-action="Update" asp-route-id="@item.Id" asp-route-activeTab="deleted-messages" asp-route-page="@Model.CurrentPage" class="btn btn-sm btn-outline-secondary px-2">
                                                                <i class="bi bi-eye"></i>
                                                            </a>
                                                            <a asp-action="MarkAsNotDeleted" asp-route-id="@item.Id" asp-route-activeTab="deleted-messages" asp-route-page="@Model.CurrentPage" class="btn btn-sm btn-outline-success px-2" title="Restore Message">
                                                                <i class="bi bi-arrow-counterclockwise"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center py-5 text-muted">
                                                    <div class="mb-2"><i class="bi bi-trash3 text-secondary fs-2"></i></div>
                                                    <p class="mb-0 small">Trash folder is empty.</p>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>

                    @* --- PAGINATION --- *@
                    @if (Model.TotalPages > 1)
                    {
                        <hr class="my-4 opacity-25" />
                        <nav aria-label="Message navigation">
                            <ul class="pagination pagination-sm justify-content-end mb-0">
                                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-activeTab="@ViewBag.ActiveTab" asp-route-page="@(Model.CurrentPage - 1)">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                        <a class="page-link" asp-action="Index" asp-route-activeTab="@ViewBag.ActiveTab" asp-route-page="@i">@i</a>
                                    </li>
                                }
                                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-activeTab="@ViewBag.ActiveTab" asp-route-page="@(Model.CurrentPage + 1)">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@* --- DYNAMIC MODAL (POPUP) --- *@
<div class="modal fade" id="messagePreviewModal" tabindex="-1" aria-labelledby="messagePreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-3">
            <div class="modal-header bg-light border-bottom-0 py-3">
                <h6 class="modal-title fw-bold text-primary m-0" id="messagePreviewModalLabel">
                    <i class="bi bi-envelope-paper-fill me-2"></i>Message Quick Preview
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3 border-bottom pb-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="fw-bold mb-0 text-dark" id="modalSenderName"></h6>
                            <small class="text-muted" id="modalSenderEmail"></small>
                        </div>
                        <span class="badge bg-secondary-subtle text-secondary font-monospace" id="modalMessageDate" style="font-size: 0.75rem;"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <span class="badge px-2 py-1.5 text-wrap mb-2 text-start" style="background-color: #f3e8ff; color: #6b21a8; border: 1px solid #e9d5ff;" id="modalSubject"></span>
                </div>
                <div class="bg-light p-3 rounded-3 border" style="max-height: 250px; overflow-y: auto;">
                    <p class="text-secondary mb-0 small" id="modalContent" style="white-space: pre-line; line-height: 1.6;"></p>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0 pb-3 pe-4">
                <button type="button" class="btn btn-sm btn-secondary px-3 py-2 fw-medium" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>



<script src="~/js/custom_admin_message_index"></script>