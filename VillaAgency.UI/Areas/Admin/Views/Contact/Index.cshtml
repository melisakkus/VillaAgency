@model List<ResultContactDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@{
    int count = 0;
}

<div class="card bg-transparent border-0 shadow-none w-100 m-0 mb-auto">

    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-3 border-bottom border-secondary-subtle position-relative px-0">
        <div class="d-flex align-items-center gap-2">
            <span class="bg-primary rounded-pill" style="width: 4px; height: 18px;"></span>
            <div>
                <h5 class="m-0 fw-bold text-body" style="letter-spacing: 0.6px; font-size: 0.95rem;">
                    CONTACT MANAGEMENT
                </h5>
            </div>
        </div>

        <a asp-area="Admin" asp-controller="Contact" asp-action="Create" class="btn btn-sm btn-primary px-3 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Add New
        </a>
    </div>

    <div class="card-body p-0">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0 w-100 text-body bg-transparent" style="table-layout: fixed;">

                <thead class="text-uppercase text-muted" style="font-size: 0.78rem; letter-spacing: 0.6px;">
                    <tr class="border-bottom border-secondary-subtle">
                        <th class="ps-3 py-2" style="width: 70px;">#</th>
                        <th class="py-2" style="width: 160px">Map URL</th>
                        <th class="py-2">Phone Number</th>
                        <th class="py-2">Email</th>
                        <th class="text-end pe-3 py-2" style="width: 200px;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr class="border-bottom border-secondary-subtle hover-row">
                                <th class="ps-3 text-muted fw-normal">@count</th>
                                <td>@item.MapUrl</td>
                                <td class="fw-semibold text-body">@item.PhoneNumber</td>
                                <td class="text-muted">@item.Email</td>
                                <td class="text-end pe-3">
                                    <a asp-area="Admin" asp-controller="Contact" append-version="true" asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning px-3 me-1">Update</a>
                                    <a asp-area="Admin" asp-controller="Contact" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger px-3">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5 w-100 border-0">
                                <div class="my-5">
                                    <i class="bi bi-folder-x display-3 text-secondary opacity-50 d-block mb-3"></i>
                                    <span class="fs-5 fw-semibold d-block mb-1 text-body">No contact data available.</span>
                                    <span class="text-muted small">Click the button above to create a new contact.</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>