@model List<ResultContactDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@{
    int count = 0;

    string FormatPhone(string p)
    {
        if (string.IsNullOrEmpty(p)) return string.Empty;
        string num = new string(p.Where(char.IsDigit).ToArray());

        return num switch
        {
            { Length: 12 } when num.StartsWith("90") => $"+90 ({num[2..5]}) {num[5..8]} {num[8..10]} {num[10..12]}",
            { Length: 11 } when num.StartsWith("0") => $"+90 ({num[1..4]}) {num[4..7]} {num[7..9]} {num[9..11]}",
            { Length: 10 } => $"+90 ({num[0..3]}) {num[3..6]} {num[6..8]} {num[8..10]}",
            _ => p
        };
    }
}

<link rel="stylesheet" href="~/css/custom_admin_contact.css" />

<div class="card bg-transparent border-0 shadow-none w-100 m-0 mb-auto">

    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-3 border-bottom border-secondary-subtle position-relative px-0">
        <div class="d-flex align-items-center gap-2">
            <span class="bg-primary rounded-pill" style="width: 4px; height: 18px;"></span>
            <div>
                <h5 class="m-0 fw-bold text-body" style="letter-spacing: 0.6px; font-size: 0.95rem;">
                    CONTACT MANAGEMENT
                </h5>
            </div>
        </div>

        <a asp-area="Admin" asp-controller="Contact" asp-action="Create" class="btn btn-sm btn-primary px-3 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Add New
        </a>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 w-100 text-body bg-transparent" style="table-layout: fixed;">
                <thead class="text-uppercase text-muted" style="font-size: 0.85rem; letter-spacing: 0.6px;">
                    <tr class="border-bottom border-secondary-subtle fw-bold text-body">
                        <th class="ps-3 py-2" style="width: 70px;">#</th>
                        <th class="py-2" style="width: 160px">Map URL</th>
                        <th class="py-2">Phone Number</th>
                        <th class="py-2">Email</th>
                        <th class="text-end pe-3 py-2" style="width: 200px;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr class="border-bottom border-secondary-subtle hover-row">
                                <th class="ps-3 text-muted fw-normal">@count</th>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.MapUrl))
                                    {
                                        @* Unified button for all map types *@
                                        <button type="button" class="btn btn-sm btn-outline-primary px-3" onclick="handleMapModal('@item.MapUrl')">
                                            <i class="bi bi-geo-alt-fill me-1"></i> View Map
                                        </button>
                                    }
                                </td>

                                <td>
                                    <a href="tel:@item.PhoneNumber" class="text-body text-decoration-none link-primary font-monospace small">
                                        <i class="bi bi-telephone-fill me-2 text-primary opacity-75"></i>
                                        @FormatPhone(item.PhoneNumber)
                                    </a>
                                </td>

                                <td>
                                    <a href="mailto:@item.Email" class="text-secondary text-decoration-none hover-primary-link">
                                        <i class="bi bi-envelope-fill me-1 text-primary"></i> @item.Email
                                    </a>
                                </td>

                                <td class="text-end pe-3">
                                    <a asp-area="Admin" asp-controller="Contact" asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning px-3 me-1">Update</a>
                                    <a asp-area="Admin" asp-controller="Contact" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger px-3">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- UNIFIED MAP MODAL -->
<div class="modal fade" id="mapModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow bg-body">
            <div class="modal-header border-bottom border-secondary-subtle py-2">
                <h6 class="modal-title fw-bold small text-uppercase text-body">
                    <i class="bi bi-geo-alt text-primary me-2"></i>Map Location
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0 overflow-hidden position-relative" style="height: 450px;">

                <!-- Iframe for Embed Links -->
                <iframe id="modalIframe" src="" class="w-100 h-100 d-none" style="border:0;" allowfullscreen=""></iframe>

                <!-- Placeholder for Short Links (Security restriction fallback) -->
                <div id="modalPlaceholder" class="d-none h-100 w-100 d-flex flex-column align-items-center justify-content-center p-5 text-center">
                    <i class="bi bi-shield-lock display-3 text-primary opacity-25 mb-3"></i>
                    <h5 class="fw-bold">Security Restriction</h5>
                    <p class="text-muted small mb-4">
                        Google doesn't allow previewing short links inside other websites. <br />
                        Please use the button below to view the location directly on Google Maps.
                    </p>
                    <a id="modalExternalLink" href="#" target="_blank" class="btn btn-primary px-4 shadow-sm">
                        Open in Google Maps <i class="bi bi-box-arrow-up-right ms-1"></i>
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>

<script src="~/js/custom_admin_contact.js"></script>

