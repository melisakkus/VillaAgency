@model DashboardCounterDto
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-3 mb-4">
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm p-3 bg-white h-100">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted mb-1 text-uppercase fw-bold small">Total Portfolios</p>
                    <h2 class="mb-0 fw-bold">@Model.TotalProductsCount</h2>
                </div>
                <div class="bg-primary bg-opacity-10 text-primary p-3 rounded">
                    <i class="bi bi-building h3 mb-0"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm p-3 bg-white h-100">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted mb-1 text-uppercase fw-bold small">Active Listings</p>
                    <h2 class="mb-0 fw-bold">@Model.ActiveProductsCount</h2>
                </div>
                <div class="bg-success bg-opacity-10 text-success p-3 rounded">
                    <i class="bi bi-house-check h3 mb-0"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm p-3 bg-white h-100">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted mb-1 text-uppercase fw-bold small">Successful Deals</p>
                    <h2 class="mb-0 fw-bold">@Model.SoldProductsCount</h2>
                </div>
                <div class="bg-warning bg-opacity-10 text-warning p-3 rounded">
                    <i class="bi bi-currency-dollar h3 mb-0"></i>
                </div>
            </div>
        </div>
    </div>
</div>
