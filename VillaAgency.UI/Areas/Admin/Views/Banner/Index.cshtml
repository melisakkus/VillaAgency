@model List<ResultBannerDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@{
    int count = 0;
}

<div class="card bg-transparent border-0 shadow-none w-100 m-0">

    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-3 border-bottom border-secondary-subtle position-relative px-0">
        <div class="d-flex align-items-center">
            <span class="d-inline-block bg-primary rounded-pill me-2" style="width: 4px; height: 18px;"></span>
            <h5 class="m-0 fw-bold text-body fs-6" style="letter-spacing: 0.5px;">BANNER MANAGEMENT</h5>
        </div>
        <a asp-controller="Banner" asp-action="CreateBanner" class="btn btn-sm btn-primary px-3 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Add New Banner
        </a>
    </div>

    <div class="card-body p-0 w-100">
        <div class="table-responsive w-100">
            <table class="table table-hover align-middle mb-0 w-100 text-body bg-transparent" style="table-layout: fixed;">
                <thead class="bg-transparent text-body text-uppercase opacity-75" style="font-size: 0.82rem; letter-spacing: 0.5px;">
                    <tr class="border-bottom border-secondary-subtle">
                        <th class="ps-3 py-3" style="width: 80px;">#</th>
                        <th class="py-3" style="width: 140px;">Image</th>
                        <th class="py-3">City</th>
                        <th class="py-3">Title</th>
                        <th class="text-end pe-3 py-3" style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr class="border-bottom border-secondary-subtle">
                                <th class="ps-3 text-muted fw-normal">@count</th>
                                <td>
                                    <img src="@item.ImageUrl" class="rounded border border-secondary-subtle" style="width: 60px; height: 40px; object-fit: cover;" alt="" />
                                </td>
                                <td class="fw-semibold">@item.City</td>
                                <td>@item.Title</td>
                                <td class="text-end pe-3">
                                    <a asp-controller="Banner" append-version="true" asp-action="UpdateBanner" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning me-1">Update</a>
                                    <a asp-controller="Banner" asp-action="DeleteBanner" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5 w-100 border-0">
                                <div class="my-5">
                                    <i class="bi bi-folder-x display-3 text-secondary opacity-50 d-block mb-3"></i>
                                    <span class="fs-5 fw-semibold d-block mb-1 text-body">No banner data available.</span>
                                    <span class="text-muted small">Click the button above to create a new banner.</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>