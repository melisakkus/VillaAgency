@model List<ResultBannerDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card bg-transparent border-0 shadow-none w-100 m-0 mb-auto">

    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-3 border-bottom border-secondary-subtle position-relative px-0">
        <div class="d-flex align-items-center gap-2">
            <span class="bg-primary rounded-pill" style="width: 4px; height: 18px;"></span>
            <div>
                <h5 class="m-0 fw-bold text-body" style="letter-spacing: 0.6px; font-size: 0.95rem;">
                    BANNER MANAGEMENT
                </h5>
            </div>
        </div>

        <a asp-area="Admin" asp-controller="Banner" asp-action="CreateBanner" class="btn btn-sm btn-primary px-3 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Add New
        </a>
    </div>

    <div class="card-body px-0 py-4">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center text-muted py-5 w-100">
                <div class="my-5">
                    <i class="bi bi-folder-x display-3 text-secondary opacity-50 d-block mb-3"></i>
                    <span class="fs-5 fw-semibold d-block mb-1 text-body">No banner data available.</span>
                    <span class="text-muted small">Click the button above to create a new banner.</span>
                </div>
            </div>
        }
        else if (Model.Count <= 2)
        {
            <div class="row row-cols-1 row-cols-md-2 g-4">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 border border-secondary-subtle shadow-sm overflow-hidden bg-body">
                            <div class="position-relative">
                                <img src="@item.ImageUrl" class="card-img-top" style="height: 220px; object-fit: cover;" alt="@item.Title" />
                                <span class="badge bg-dark bg-opacity-75 position-absolute top-0 start-0 m-3 fs-7 fw-bold shadow-sm">
                                    @item.City
                                </span>
                            </div>
                            <div class="card-body d-flex flex-column justify-content-between">
                                <h6 class="card-title fw-bold text-body mb-3">@item.Title</h6>
                                <div class="d-flex justify-content-end gap-2 border-top border-secondary-subtle pt-3">
                                    <a asp-area="Admin" asp-controller="Banner" append-version="true" asp-action="UpdateBanner" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning px-3">Update</a>
                                    <a asp-area="Admin" asp-controller="Banner" asp-action="DeleteBanner" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger px-3">Delete</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div id="bannerCarousel" class="carousel slide shadow-sm rounded border border-secondary-subtle overflow-hidden" data-bs-ride="carousel">

                <div class="carousel-indicators">
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <button type="button" data-bs-target="#bannerCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i + 1)"></button>
                    }
                </div>

                <div class="carousel-inner">
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var item = Model[i];
                        <div class="carousel-item @(i == 0 ? "active" : "")" data-bs-interval="4000">
                            <div class="position-relative w-100" style="height: 400px;">
                                <img src="@item.ImageUrl" class="d-block w-100 h-100" style="object-fit: cover;" alt="@item.Title" />
                                <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.2) 60%, rgba(0,0,0,0) 100%);"></div>

                                <div class="carousel-caption d-flex flex-column align-items-start text-start justify-content-end h-100 bottom-0 pb-4 px-4">
                                    <span class="badge bg-primary mb-2 shadow">@item.City</span>
                                    <h4 class="fw-bold text-white mb-3" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.8);">@item.Title</h4>

                                    <div class="d-flex gap-2">
                                        <a asp-area="Admin" asp-controller="Banner" append-version="true" asp-action="UpdateBanner" asp-route-id="@item.Id" class="btn btn-sm btn-warning px-3 fw-semibold shadow">
                                            <i class="bi bi-pencil-square me-1"></i> Update
                                        </a>
                                        <a asp-area="Admin" asp-controller="Banner" asp-action="DeleteBanner" asp-route-id="@item.Id" class="btn btn-sm btn-danger px-3 fw-semibold shadow">
                                            <i class="bi bi-trash me-1"></i> Delete
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <button class="carousel-control-prev" type="button" data-bs-target="#bannerCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#bannerCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        }
    </div>
</div>