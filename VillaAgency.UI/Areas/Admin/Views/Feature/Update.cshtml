@model UpdateFeatureDto
@{
    ViewData["Title"] = "Update";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/custom_admin_feature.css" />

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary-subtle">
        <div class="d-flex align-items-center gap-2">
            <span class="bg-primary rounded-pill" style="width: 4px; height: 18px;"></span>
            <h5 class="mb-0 fw-bold text-body" style="letter-spacing: 0.6px; font-size: 0.95rem; text-transform: uppercase;">
                Update Feature
            </h5>
        </div>
        <a asp-controller="Feature" asp-action="Index" class="btn btn-sm btn-outline-secondary px-3 shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <form method="post" id="updateFeatureForm">
        <input type="hidden" asp-for="Id" />

        <div class="row g-4">

            <div class="col-12 col-lg-7">
                <div class="card border border-secondary-subtle shadow-sm bg-body">
                    <div class="card-body p-4">

                        <div class="row">
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label fw-semibold text-body small">Title</label>
                                    <input asp-for="Title" class="form-control" id="inputTitle" placeholder="Feature title..." />
                                    <span asp-validation-for="Title" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="IsActive" class="form-label fw-semibold text-body small">Status</label>
                                    <select asp-for="IsActive" class="form-select">
                                        <option value="true">Active</option>
                                        <option value="false">Passive</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ImageUrl" class="form-label fw-semibold text-body small">Image URL</label>
                            <div class="input-group">
                                <span class="input-group-text border-secondary-subtle"><i class="bi bi-link-45deg"></i></span>
                                <input asp-for="ImageUrl" id="imageUrlInput" class="form-control" placeholder="https://example.com/image.jpg" />
                            </div>
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>

                        <div class="mt-4 pt-3 border-top border-secondary-subtle">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="mb-0 fw-bold text-body small text-uppercase">FAQs</h6>
                                <button type="button" class="btn btn-xs btn-outline-primary py-1 px-2" onclick="addFaq()">+ Add FAQ</button>
                            </div>
                            <div id="faqContainer">
                                @for (int i = 0; i < Model.FAQs.Count; i++)
                                {
                                    <div class="row g-2 mb-3 faq-item">

                                        <div class="col-5">
                                            <input asp-for="FAQs[i].Question"
                                                   class="form-control form-control-sm"
                                                   placeholder="Question" />
                                            <span asp-validation-for="FAQs[i].Question"
                                                  class="text-danger small"></span>
                                        </div>

                                        <div class="col-6">
                                            <input asp-for="FAQs[i].Answer"
                                                   class="form-control form-control-sm"
                                                   placeholder="Answer" />
                                            <span asp-validation-for="FAQs[i].Answer"
                                                  class="text-danger small"></span>
                                        </div>

                                        <div class="col-1 text-end">
                                            @if (i > 0)
                                            {
                                                <button type="button"
                                                        class="btn btn-sm text-danger border-0"
                                                        onclick="removeItem(this,'faq-item','FAQs')">
                                                    ✕
                                                </button>
                                            }
                                        </div>

                                    </div>
                                }
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-top border-secondary-subtle">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="mb-0 fw-bold text-body small text-uppercase">Feature Details</h6>
                                <button type="button" class="btn btn-xs btn-outline-primary py-1 px-2" onclick="addDetail()">+ Add Detail</button>
                            </div>
                            <div id="detailContainer">
                                @for (int i = 0; i < Model.FeatureDetails.Count; i++)
                                {
                                    <div class="row g-2 mb-3 detail-item">

                                        <input asp-for="FeatureDetails[i].Icon" type="hidden" />

                                        <div class="col-5">
                                            <input asp-for="FeatureDetails[i].Title"
                                                   class="form-control form-control-sm"
                                                   placeholder="Detail Title" />
                                            <span asp-validation-for="FeatureDetails[i].Title"
                                                  class="text-danger small"></span>
                                        </div>

                                        <div class="col-6">
                                            <input asp-for="FeatureDetails[i].SubTitle"
                                                   class="form-control form-control-sm"
                                                   placeholder="Detail Subtitle" />
                                            <span asp-validation-for="FeatureDetails[i].SubTitle"
                                                  class="text-danger small"></span>
                                        </div>

                                        <div class="col-1 text-end">
                                            @if (i > 0)
                                            {
                                                <button type="button"
                                                        class="btn btn-sm text-danger border-0"
                                                        onclick="removeItem(this,'detail-item','FeatureDetails')">
                                                    ✕
                                                </button>
                                            }
                                        </div>

                                    </div>
                                }
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-3 mt-4 border-top border-secondary-subtle">
                            <a asp-controller="Feature" asp-action="Index" class="btn btn-sm btn-outline-secondary px-4">Cancel</a>
                            <button type="submit" class="btn btn-sm btn-primary px-4 shadow-sm">Save Changes</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-5">
                <div class="card border border-secondary-subtle shadow-sm bg-body h-100">
                    <div class="card-header bg-transparent border-bottom border-secondary-subtle py-3">
                        <h6 class="m-0 fw-semibold text-muted small text-uppercase">
                            <i class="bi bi-eye me-1 text-primary"></i> Current Preview
                        </h6>
                    </div>
                    <div class="card-body d-flex align-items-center justify-content-center bg-light-subtle p-4" style="min-height: 300px;">

                        <div id="previewCard" class="card border border-secondary-subtle shadow-sm overflow-hidden bg-body w-100 d-none" style="max-width: 400px;">
                            <img id="imagePreview" src="#" class="card-img-top" style="height: 220px; object-fit: cover;" alt="Preview" />
                            <div class="card-body">
                                <h6 id="previewTitle" class="card-title fw-bold text-body mb-0">Feature Title</h6>
                            </div>
                        </div>

                        <div id="previewPlaceholder" class="text-center py-5 text-muted">
                            <i class="bi bi-image display-4 opacity-25 d-block mb-3"></i>
                            <span class="small fw-medium">Checking current image...</span>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script src="~/js/custom_admin_feature.js"></script>