@model VillaAgency.Dto.FeatureDtos.CreateFeatureDto
@{
    ViewData["Title"] = "Create";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0 fw-bold text-uppercase">Create New Feature</h5>
        <a asp-controller="Feature" asp-action="Index" class="btn btn-sm btn-outline-secondary">Back</a>
    </div>

    <form asp-controller="Feature" asp-action="Create" method="post" id="createFeatureForm">
        <div class="row g-4">
            <div class="col-12 col-lg-6">
                <div class="card border-0 shadow-sm p-4">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">Title</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger" style="font-size: 12px;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label fw-semibold">Image URL</label>
                        <input asp-for="ImageUrl" class="form-control" id="imageUrlInput" placeholder="https://..." />
                        <span asp-validation-for="ImageUrl" class="text-danger" style="font-size: 12px;"></span>
                    </div>

                    <div class="mb-3 text-center">
                        <div id="previewContainer" class="d-none border rounded p-2">
                            <img id="imagePreview" src="#" alt="Preview" style="max-width:100%;max-height:140px;object-fit:contain;" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="d-flex flex-column gap-4">

                    <div class="card border-0 shadow-sm p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0 fw-bold">FAQs</h6>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="addFaq()">+ Add FAQ</button>
                        </div>

                        <div id="faqContainer">
                            <div class="row g-2 mb-3 faq-item align-items-start">
                                <div class="col-5">
                                    <input name="FAQs[0].Question" class="form-control form-control-sm" placeholder="Question" />
                                    <span asp-validation-for="FAQs[0].Question" class="text-danger d-block mt-1" data-valmsg-for="FAQs[0].Question" data-valmsg-replace="true" style="font-size: 11px;"></span>
                                </div>
                                <div class="col-6">
                                    <input name="FAQs[0].Answer" class="form-control form-control-sm" placeholder="Answer" />
                                    <span asp-validation-for="FAQs[0].Answer" class="text-danger d-block mt-1" data-valmsg-for="FAQs[0].Answer" data-valmsg-replace="true" style="font-size: 11px;"></span>
                                </div>
                                <div class="col-1 text-end pt-1">
                                    <button type="button" class="btn btn-sm text-danger p-0 border-0" onclick="removeItem(this, 'faq-item', 'FAQs')">✕</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0 fw-bold">Feature Details</h6>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="addDetail()">+ Add Detail</button>
                        </div>

                        <div id="detailContainer">
                            <div class="row g-2 mb-3 detail-item align-items-start">
                                <input type="hidden" name="FeatureDetails[0].Icon" value="bi bi-star" />
                                <div class="col-5">
                                    <input name="FeatureDetails[0].Title" class="form-control form-control-sm" placeholder="Title" />
                                    <span asp-validation-for="FeatureDetails[0].Title" class="text-danger d-block mt-1" data-valmsg-for="FeatureDetails[0].Title" data-valmsg-replace="true" style="font-size: 11px;"></span>
                                </div>
                                <div class="col-6">
                                    <input name="FeatureDetails[0].SubTitle" class="form-control form-control-sm" placeholder="SubTitle" />
                                    <span asp-validation-for="FeatureDetails[0].SubTitle" class="text-danger d-block mt-1" data-valmsg-for="FeatureDetails[0].SubTitle" data-valmsg-replace="true" style="font-size: 11px;"></span>
                                </div>
                                <div class="col-1 text-end pt-1">
                                    <button type="button" class="btn btn-sm text-danger p-0 border-0" onclick="removeItem(this, 'detail-item', 'FeatureDetails')">✕</button>
                                </div>
                            </div>
                    </div>

                </div>
            </div>

            <div class="col-12">
                <div class="d-flex justify-content-end gap-2">
                    <a asp-controller="Feature" asp-action="Index" class="btn btn-light border px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Save Feature</button>
                </div>
            </div>
        </div>
    </form>
</div>

<script src="~/js/custom_admin_feature_create.js"></script>