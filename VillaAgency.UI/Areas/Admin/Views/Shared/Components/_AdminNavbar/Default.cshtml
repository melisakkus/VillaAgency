@using VillaAgency.Entity.Identity.Constants
@model Tuple<List<ResultMessageDto>, int>

<div class="navbar-actions ms-auto">
    <button class="icon-button theme-toggle" type="button" data-theme-toggle aria-label="Switch color theme" title="Switch color theme">
        <i class="bi bi-moon-stars" data-theme-icon aria-hidden="true"></i>
    </button>

    <div class="dropdown">
        <button class="icon-button" type="button" data-bs-toggle="dropdown" aria-expanded="false">
            @if (Model != null && Model.Item2 > 0)
            {
                <span class="notification-dot"></span>
            }
            <i class="bi bi-bell"></i>
        </button>

        <div class="dropdown-menu dropdown-menu-end notification-menu shadow-lg border rounded-3 overflow-hidden" style="width: 340px;">

            <div class="dropdown-header d-flex justify-content-between align-items-center py-3 px-3 border-bottom custom-dropdown-header">
                <span class="fw-bold fs-6 header-title">Messages</span>
                <span class="badge bg-primary rounded-pill">@Model?.Item2</span>
            </div>

            <div class="message-list-scroll">
                @if (Model == null || Model.Item1 == null || !Model.Item1.Any())
                {
                    <div class="text-center py-4 text-muted small">
                        <i class="bi bi-envelope-open d-block fs-3 mb-2"></i>
                        No new messages
                    </div>
                }
                else
                {
                    foreach (var item in Model.Item1)
                    {
                        var firstLetter = !string.IsNullOrEmpty(item.Name) ? item.Name[0].ToString().ToUpper() : "M";

                        <div class="message-item-wrapper custom-border-bottom">
                            <a class="dropdown-item d-flex align-items-start py-3 px-3 custom-dropdown-item"
                               asp-area="Admin"
                               asp-controller="Message"
                               asp-action="Update"
                               asp-route-id="@item.Id">

                                <div class="avatar-circle-placeholder me-3 d-flex align-items-center justify-content-center fw-bold rounded-circle">
                                    @firstLetter
                                </div>

                                <div class="w-100">
                                    <div class="d-flex justify-content-between align-items-baseline mb-1">
                                        <h6 class="mb-0 text-truncate fw-semibold custom-item-name" style="max-width: 160px; font-size: 0.9rem;">
                                            @(item.Name ?? "New Inquiry")
                                        </h6>
                                        <small class="text-muted text-nowrap style-date" style="font-size: 0.75rem;">
                                            @item.MessageDate.ToString("dd MMM")
                                        </small>
                                    </div>
                                    <p class="mb-0 text-muted text-truncate small custom-item-subject" style="font-size: 0.825rem; max-width: 220px;">
                                        @item.Subject
                                    </p>
                                </div>
                            </a>
                        </div>
                    }
                }
            </div>

            <div class="p-2 border-top text-center custom-dropdown-footer">
                <a asp-area="Admin" asp-controller="Message" asp-action="Index" class="text-primary fw-semibold small d-block py-1 hover-underline" style="font-size: 0.85rem; text-decoration: none;">
                    View All Messages <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="dropdown">
        <button class="profile-button" type="button" aria-expanded="false">
            <img class="avatar-img avatar-sm" src="/adminhmd-1.0.0/assets/images/avatar/adminicon.png" alt="Profile">
            <span class="profile-name d-none d-sm-inline">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    if (User.IsInRole(Roles.Admin))
                    {
                        @:Admin
                    }
                    else if (User.IsInRole(Roles.Manager))
                    {
                        @:Manager
                    }
                    else
                    {
                        @User.Identity.Name
                    }
                }
            </span>
        </button>
    </div>
</div>