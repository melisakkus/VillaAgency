@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

    @await Component.InvokeAsync("_AdminHead")

<body>
    <div class="admin-shell">
        <div class="sidebar-backdrop" data-sidebar-close></div>

        @await Component.InvokeAsync("_AdminSideBar")

        <div class="admin-main">
           
            <nav class="navbar admin-navbar navbar-expand bg-white">                         
                <div class="container-fluid px-3 px-lg-4">

                    @await Component.InvokeAsync("_AdminToogleSearch")
                    
                    @await Component.InvokeAsync("_AdminNavbar")
                  
                </div>
            </nav>

            <main class="dashboard-content">
                <div class="container-fluid px-3 px-lg-4 py-4">
                    <section class="panel blank-panel">
                        @RenderBody()
                    </section>
                </div>
            </main>

            @await Component.InvokeAsync("_AdminFooter")

        </div>
    </div>

    @await Component.InvokeAsync("_AdminScripts")


</body>
</html>

