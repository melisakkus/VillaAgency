@model List<ResultVideoViewDto>
@{
    ViewData["Title"] = "Video Management";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@{
    int totalCount = Model != null ? Model.Count : 0;
    int currentNumber = totalCount;
}

<div class="card bg-transparent border-0 shadow-none w-100 m-0 mb-auto">

    <!-- Header Section -->
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-3 border-bottom border-secondary-subtle px-0">
        <div class="d-flex align-items-center gap-2">
            <span class="bg-primary rounded-pill" style="width: 4px; height: 18px;"></span>
            <div>
                <h5 class="m-0 fw-bold text-body" style="letter-spacing: 0.6px; font-size: 0.95rem;">
                    VIDEO MANAGEMENT
                </h5>
            </div>
        </div>

        <a asp-area="Admin" asp-controller="Video" asp-action="Create" class="btn btn-sm btn-primary px-3 shadow-sm d-flex align-items-center gap-1">
            <i class="bi bi-plus-lg"></i> Add New Video
        </a>
    </div>

    <!-- Body Section -->
    <div class="card-body px-0 py-4 text-body">
        @if (Model != null && Model.Any())
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card video-card bg-transparent border border-secondary-subtle rounded-3 overflow-hidden h-100 shadow-sm transition-all @(item.IsActive ? "" : "opacity-75")">

                            <div class="position-relative video-thumbnail-container bg-dark" style="height: 180px;">
                                <div class="video-preview-bg position-absolute top-0 start-0 w-100 h-100" data-video-url="@item.VideoUrl"></div>

                                <div class="thumbnail-overlay d-flex align-items-center justify-content-center position-absolute top-0 start-0 w-100 h-100 transition-all opacity-0">
                                    <button class="btn btn-primary rounded-circle play-trigger-btn shadow"
                                            data-bs-toggle="modal"
                                            data-bs-target="#videoPlayerModal"
                                            data-video-src="@item.VideoUrl">
                                        <i class="bi bi-play-fill fs-4"></i>
                                    </button>
                                </div>

                                <span class="position-absolute top-3 start-3 badge bg-primary text-white rounded-2 px-2.5 py-1.5 fw-bold shadow-sm z-3">
                                    #@currentNumber
                                </span>
                            </div>

                            <div class="card-body p-3 d-flex flex-column justify-content-between">

                                <div class="mb-4">
                                    <div class="text-xs text-uppercase fw-bold text-primary mb-2 opacity-75" style="font-size: 0.65rem; letter-spacing: 1px;">
                                        Source URL
                                    </div>
                                    <a href="@item.VideoUrl" target="_blank" rel="noopener noreferrer"
                                       class="text-decoration-none d-block bg-body-tertiary bg-opacity-50 p-2 rounded-2 border border-secondary-subtle transition-all source-link-box"
                                       title="Click to open link in a new tab">
                                        <div class="d-flex align-items-center justify-content-between gap-2 overflow-hidden">
                                            <div class="d-flex align-items-center gap-2 overflow-hidden">
                                                <i class="bi bi-link-45deg text-primary flex-shrink-0" style="font-size: 1.1rem;"></i>
                                                <span class="text-body-secondary small text-truncate fw-medium">@item.VideoUrl</span>
                                            </div>
                                            <i class="bi bi-box-arrow-up-right text-primary opacity-50 flex-shrink-0" style="font-size: 0.75rem;"></i>
                                        </div>
                                    </a>
                                </div>

                                <div class="d-flex justify-content-between align-items-center border-top border-secondary-subtle pt-3">

                                    <div class="d-flex align-items-center gap-2">
                                        <button class="btn btn-xs btn-outline-primary px-3 py-1 fw-semibold"
                                                data-bs-toggle="modal"
                                                data-bs-target="#videoPlayerModal"
                                                data-video-src="@item.VideoUrl">
                                            Preview
                                        </button>
                                        @if (item.IsActive)
                                        {
                                            <a asp-action="MakeItPassive" asp-route-id="@item.Id"
                                               class="status-toggle-btn active-status d-inline-flex align-items-center gap-3 px-3 py-1 text-decoration-none"
                                               title="Make it Passive">
                                                <span class="status-pulse-dot"></span>
                                                <span class="status-text fw-semibold">Active</span>
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-action="MakeItActive" asp-route-id="@item.Id"
                                               class="status-toggle-btn passive-status d-inline-flex align-items-center gap-3 px-3 py-1 text-decoration-none"
                                               title="Click to Activate">
                                                <i class="bi bi-circle-fill" style="font-size: 0.45rem;"></i>
                                                <span class="status-text fw-semibold">Passive</span>
                                            </a>
                                        }
                                    </div>

                                    <div class="d-flex gap-1">
                                        <a asp-area="Admin" asp-controller="Video" asp-action="Update" asp-route-id="@item.Id"
                                           class="btn btn-xs btn-outline-warning px-2.5 py-1">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-area="Admin" asp-controller="Video" asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-xs btn-outline-danger px-2.5 py-1">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    currentNumber--;
                }
            </div>
        }
    </div>
</div>

<div class="modal fade" id="videoPlayerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 overflow-hidden rounded-3 shadow-lg bg-dark">
            <div class="modal-header border-0 bg-transparent py-2 px-3 position-absolute top-0 end-0 z-3">
                <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0 bg-black">
                <div class="ratio ratio-16x9" id="modalVideoContainer"></div>
            </div>
        </div>
    </div>
</div>

<style>
    .video-card {
        transition: all 0.25s ease;
    }

        .video-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
        }

    [data-bs-theme="dark"] .video-card {
        background-color: rgba(255, 255, 255, 0.04) !important;
    }

    .btn-xs {
        font-size: 0.72rem;
        border-radius: 6px;
    }

    .status-toggle-btn {
        font-size: 0.72rem;
        border-radius: 6px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid transparent;
        min-width: 100px;
        display: inline-flex;
        justify-content: flex-start; 
        padding-left: 12px;
    }

        .status-toggle-btn.active-status {
            background-color: rgba(25, 135, 84, 0.1);
            border-color: rgba(25, 135, 84, 0.2);
            color: #198754;
        }

    [data-bs-theme="dark"] .status-toggle-btn.active-status {
        background-color: rgba(40, 167, 69, 0.15);
        border-color: rgba(40, 167, 69, 0.3);
        color: #4cd137;
    }

    .status-toggle-btn.active-status:hover {
        background-color: rgba(220, 53, 69, 0.1);
        border-color: rgba(220, 53, 69, 0.3);
        color: #dc3545;
    }

    .status-toggle-btn.passive-status {
        background-color: rgba(255, 193, 7, 0.12); 
        border-color: rgba(255, 193, 7, 0.3); 
        color: #997404; 
    }

    [data-bs-theme="dark"] .status-toggle-btn.passive-status {
        background-color: rgba(255, 193, 7, 0.08);
        border-color: rgba(255, 193, 7, 0.25);
        color: #ffc107;
    }

    .status-toggle-btn.passive-status:hover {
        background-color: rgba(25, 135, 84, 0.15) !important;
        border-color: rgba(25, 135, 84, 0.4) !important;
        color: #198754 !important;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
    }

        .status-toggle-btn.passive-status:hover .bi-circle-fill {
            color: #198754 !important;
        }

    .status-toggle-btn.passive-status .bi-circle-fill {
        color: #ffc107;
        opacity: 0.8;
    }

    .status-toggle-btn.passive-status:hover .status-text {
        font-size: 0;
    }

    .status-toggle-btn.active-status:hover .status-text::before {
        content: 'Disable';
        font-size: 0.72rem;
    }

    .status-toggle-btn.active-status:hover .status-text {
        font-size: 0;
    }

        .status-toggle-btn.active-status:hover .status-text::before {
            content: 'Disable';
            font-size: 0.72rem;
        }

    .status-toggle-btn.passive-status:hover .status-text {
        font-size: 0;
    }

        .status-toggle-btn.passive-status:hover .status-text::before {
            content: 'Enable';
            font-size: 0.72rem;
        }

    .status-pulse-dot {
        width: 7px;
        height: 7px;
        background-color: currentColor;
        border-radius: 50%;
        display: inline-block;
        animation: activePulse 2s infinite;
    }

    @@keyframes activePulse {
        0% {
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.4);
        }

        70% {
            box-shadow: 0 0 0 6px rgba(25, 135, 84, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0);
        }
    }

    .btn-outline-warning {
        border-width: 1px;
    }
    [data-bs-theme="dark"] .btn-outline-warning i {
        color: #ffc107;
    }

    [data-bs-theme="dark"] .btn-outline-warning:hover i {
        color: #000;
    }
</style>

<script>
    // YouTube Thumbnail ve Modal Logic aynı kalabilir, değişmedi.
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".video-preview-bg").forEach(container => {
            const url = container.getAttribute("data-video-url");
            const ytMatch = url?.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/ ]{11})/i);
            if (ytMatch) container.style.backgroundImage = `url('https://img.youtube.com/vi/${ytMatch[1]}/mqdefault.jpg')`;
        });

        const modalVideo = document.getElementById('modalVideoContainer');
        document.getElementById('videoPlayerModal').addEventListener('show.bs.modal', function (e) {
            const url = e.relatedTarget.getAttribute('data-video-src');
            const ytMatch = url?.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/ ]{11})/i);
            modalVideo.innerHTML = ytMatch
                ? `<iframe src="https://www.youtube.com/embed/${ytMatch[1]}?autoplay=1" allow="autoplay; encrypted-media" allowfullscreen class="border-0 w-100 h-100"></iframe>`
                : `<video src="${url}" controls autoplay class="w-100 h-100"></video>`;
        });
        document.getElementById('videoPlayerModal').addEventListener('hide.bs.modal', () => modalVideo.innerHTML = "");
    });
</script>