@model CreateVideoViewDto
@{
    ViewData["Title"] = "Create Video";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/custom_admin_videoview.css" />

<div class="card bg-transparent border-0 shadow-none w-100 m-0 d-flex flex-column" style="min-height: calc(100vh - 180px);">

    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-2 border-bottom border-secondary-subtle px-0 flex-shrink-0">
        <div class="d-flex align-items-center gap-2">
            <span class="bg-primary rounded-pill" style="width: 4px; height: 16px;"></span>
            <h6 class="m-0 fw-bold text-body text-uppercase" style="letter-spacing: 0.5px; font-size: 0.85rem;">
                Add New Video Content
            </h6>
        </div>
        <a asp-area="Admin" asp-controller="Video" asp-action="Index" class="btn btn-sm btn-outline-secondary px-3 py-1" style="font-size: 0.75rem;">
            <i class="bi bi-arrow-left me-1"></i> Back to Gallery
        </a>
    </div>

    <div class="card-body px-0 d-flex align-items-center justify-content-center flex-grow-1 py-3">
        <div class="row justify-content-center w-100 m-0">
            <div class="col-12 col-lg-9 col-xl-7">

                <div class="custom-premium-card border border-secondary-subtle rounded-3 shadow-sm overflow-hidden">

                    <form method="post" class="p-4 p-md-5">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4 text-center">
                            <div class="mx-auto bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 64px; height: 64px;">
                                <i class="bi bi-play-circle-fill display-6"></i>
                            </div>
                            <h5 class="fw-bold text-body mb-1">Video Source</h5>
                            <p class="text-muted small">Enter the link of the video you want to showcase.</p>
                        </div>

                        <div class="mb-4">
                            <label asp-for="VideoUrl" class="form-label fw-bold text-body small mb-2 text-uppercase" style="letter-spacing: 0.5px;">
                                <i class="bi bi-link-45deg text-primary me-1"></i> Video URL
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-secondary-subtle text-secondary">
                                    <i class="bi bi-globe"></i>
                                </span>
                                <input asp-for="VideoUrl"
                                       class="form-control custom-input shadow-none py-2.5"
                                       placeholder="https://www.youtube.com/watch?v=..." />
                            </div>
                            <span asp-validation-for="VideoUrl" class="text-danger small fw-medium mt-1 d-block"></span>
                        </div>

                        <div id="liveVideoPreviewContainer" class="mb-4 d-none">
                            <label class="form-label fw-bold text-body small mb-2 text-uppercase" style="letter-spacing: 0.5px;">
                                <i class="bi bi-eye text-primary me-1"></i> Video Preview
                            </label>
                            <div class="card bg-dark border border-secondary-subtle rounded-3 overflow-hidden shadow-sm shadow-sm position-relative" style="height: 220px;">

                                <div id="liveVideoPreviewBg" class="position-absolute top-0 start-0 w-100 h-100" style="background-size: cover; background-position: center;"></div>

                                <div class="d-flex align-items-center justify-content-center position-absolute top-0 start-0 w-100 h-100 bg-black bg-opacity-20">
                                    <button type="button" class="btn btn-primary rounded-circle shadow p-3 d-flex align-items-center justify-content-center"
                                            id="livePreviewPlayBtn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#videoPlayerModal"
                                            data-video-src="">
                                        <i class="bi bi-play-fill fs-4" style="margin-left: 2px;"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="p-3 rounded-3 custom-info-box border border-secondary-subtle border-start-3 border-start-primary mb-4">
                            <div class="d-flex gap-3 align-items-center">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 32px; height: 32px;">
                                    <i class="bi bi-info-circle-fill fs-5"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="m-0 text-body small opacity-90 fw-medium" style="line-height: 1.4;">
                                        Please provide a valid video URL. Currently, only link-based video content can be added to the gallery.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-center gap-3">
                            <button type="submit" class="btn btn-primary px-5 py-2.5 fw-bold shadow-sm d-flex align-items-center gap-2">
                                <i class="bi bi-cloud-arrow-up-fill"></i> Add Video to Gallery
                            </button>
                            <a asp-area="Admin" asp-controller="Video" asp-action="Index" class="btn btn-outline-secondary px-4 py-2.5 fw-semibold">
                                Cancel
                            </a>
                        </div>
                    </form>

                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="videoPlayerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 overflow-hidden rounded-3 shadow-lg bg-dark">
            <div class="modal-header border-0 bg-transparent py-2 px-3 position-absolute top-0 end-0 z-3">
                <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0 bg-black">
                <div class="ratio ratio-16x9" id="modalVideoContainer"></div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/custom_admin_videoview.js"></script>