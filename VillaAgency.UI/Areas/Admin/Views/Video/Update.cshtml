@model UpdateVideoViewDto
@{
    ViewData["Title"] = "Update Video";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card bg-transparent border-0 shadow-none w-100 m-0 d-flex flex-column" style="min-height: calc(100vh - 180px);">

    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-2 border-bottom border-secondary-subtle px-0 flex-shrink-0">
        <div class="d-flex align-items-center gap-2">
            <span class="bg-primary rounded-pill" style="width: 4px; height: 16px;"></span>
            <h6 class="m-0 fw-bold text-body text-uppercase" style="letter-spacing: 0.5px; font-size: 0.85rem;">
                Update Video Content
            </h6>
        </div>
        <a asp-area="Admin" asp-controller="Video" asp-action="Index" class="btn btn-sm btn-outline-secondary px-3 py-1" style="font-size: 0.75rem;">
            <i class="bi bi-arrow-left me-1"></i> Back to Gallery
        </a>
    </div>

    <div class="card-body px-0 d-flex align-items-center justify-content-center flex-grow-1 py-3">
        <div class="row justify-content-center w-100 m-0">
            <div class="col-12 col-lg-9 col-xl-7">

                <div class="custom-premium-card border border-secondary-subtle rounded-3 shadow-sm overflow-hidden">

                    <form method="post" class="p-4 p-md-5">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4 text-center">
                            <div class="mx-auto bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 64px; height: 64px;">
                                <i class="bi bi-pencil-fill display-6"></i>
                            </div>
                            <h5 class="fw-bold text-body mb-1">Edit Video Link</h5>
                            <p class="text-muted small">You are currently modifying the existing video source.</p>
                        </div>

                        <div class="mb-4">
                            <label asp-for="VideoUrl" class="form-label fw-bold text-body small mb-2 text-uppercase" style="letter-spacing: 0.5px;">
                                <i class="bi bi-link-45deg text-primary me-1"></i> Video URL
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-secondary-subtle text-secondary">
                                    <i class="bi bi-globe"></i>
                                </span>
                                <input asp-for="VideoUrl"
                                       class="form-control custom-input shadow-none py-2.5"
                                       placeholder="Paste your video link here..." />
                            </div>
                            <span asp-validation-for="VideoUrl" class="text-danger small fw-medium mt-1 d-block"></span>
                        </div>

                        <div class="p-3 rounded-3 bg-body-tertiary border border-secondary-subtle mb-4 shadow-none">
                            <div class="d-flex gap-3 align-items-center">
                                <i class="bi bi-info-circle-fill text-warning"></i>
                                <span class="small text-body-secondary fw-medium">
                                    Make sure the URL is still valid. The preview will update automatically on the index page.
                                </span>
                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-center gap-3">
                            <button type="submit" class="btn btn-primary px-5 py-2.5 fw-bold shadow-sm d-flex align-items-center gap-2">
                                <i class="bi bi-check-lg"></i> Update Video
                            </button>
                            <a asp-area="Admin" asp-controller="Video" asp-action="Index" class="btn btn-outline-secondary px-4 py-2.5 fw-semibold">
                                Cancel
                            </a>
                        </div>
                    </form>

                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .custom-premium-card {
        transition: background-color 0.2s ease;
    }

    [data-bs-theme="light"] .custom-premium-card,
    html:not([data-bs-theme="dark"]) .custom-premium-card {
        background-color: #ffffff !important;
    }

    [data-bs-theme="dark"] .custom-premium-card {
        background-color: rgba(255, 255, 255, 0.03) !important;
    }

    .custom-input {
        background-color: rgba(var(--bs-text-color-rgb), 0.02) !important;
        border: 1px solid var(--bs-border-color) !important;
        color: var(--bs-body-color) !important;
        font-size: 0.9rem;
    }

        .custom-input:focus {
            background-color: transparent !important;
            border-color: var(--bs-primary) !important;
            box-shadow: 0 0 0 0.25rem rgba(var(--bs-primary-rgb), 0.05) !important;
        }

        .custom-input::placeholder {
            font-size: 0.85rem;
            opacity: 0.4;
            font-style: italic;
        }

    .input-group-text {
        border-right: none !important;
    }

    .custom-input {
        border-left: none !important;
    }

    .border-start-3 {
        border-left-width: 3px !important;
    }

    .border-start-primary {
        border-left-color: var(--bs-primary) !important;
    }

    [data-bs-theme="light"] .custom-info-box,
    html:not([data-bs-theme="dark"]) .custom-info-box {
        background-color: rgba(var(--bs-primary-rgb), 0.03) !important;
    }

    [data-bs-theme="dark"] .custom-info-box {
        background-color: rgba(255, 255, 255, 0.02) !important;
    }
</style>