@model List<ResultQuestionDto>
@{
    ViewData["Title"] = "Question Management";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@{
    int totalCount = Model != null ? Model.Count : 0;
    int currentNumber = totalCount;
}

<link rel="stylesheet" href="~/css/custom_admin_question.css" />

<div class="card bg-transparent border-0 shadow-none w-100 m-0 mb-auto">

    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-3 border-bottom border-secondary-subtle position-relative px-0">
        <div class="d-flex align-items-center gap-2">
            <span class="bg-primary rounded-pill" style="width: 4px; height: 18px;"></span>
            <div>
                <h5 class="m-0 fw-bold text-body" style="letter-spacing: 0.6px; font-size: 0.95rem;">
                    QUESTION MANAGEMENT
                </h5>
            </div>
        </div>

        <a asp-area="Admin" asp-controller="Question" asp-action="Create" class="btn btn-sm btn-primary px-3 shadow-sm d-flex align-items-center gap-1">
            <i class="bi bi-plus-lg"></i> Add New
        </a>
    </div>

    <div class="card-body px-0 py-4">
        @if (Model != null && Model.Any())
        {
            <div class="accordion custom-faq-accordion d-flex flex-column gap-3" id="faqAccordion">
                @foreach (var item in Model)
                {
                    <div class="accordion-item bg-transparent border border-secondary-subtle rounded-3 overflow-hidden shadow-sm">

                        <h2 class="accordion-header" id="heading-@item.Id">
                            <button class="accordion-button collapsed bg-transparent text-body fs-6 fw-semibold py-3 px-4 d-flex align-items-center justify-content-between shadow-none"
                                    type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@item.Id" aria-expanded="false" aria-controls="collapse-@item.Id">
                                <div class="d-flex align-items-center gap-3 text-start pe-3">
                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-2 px-2.5 py-1.5 fw-bold">#@currentNumber</span>
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-question-circle text-primary opacity-75"></i>
                                        <span>@item.QuestionText</span>
                                    </div>
                                </div>
                            </button>
                        </h2>

                        <div id="collapse-@item.Id" class="accordion-collapse collapse" aria-labelledby="heading-@item.Id" data-bs-parent="#faqAccordion">
                            <div class="accordion-body bg-transparent border-top border-secondary-subtle pt-3 pb-4 px-4">

                                <div class="mb-4 text-body-secondary p-3 rounded-2 custom-answer-box">
                                    <div class="d-flex gap-2">
                                        <i class="bi bi-chat-left-text text-primary mt-1 opacity-75"></i>
                                        <p class="m-0 small lh-base">@item.Answer</p>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-end gap-2 border-top border-secondary-subtle pt-3">
                                    <a asp-area="Admin" asp-controller="Question" append-version="true" asp-action="Update" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-warning px-3 d-inline-flex align-items-center gap-1 shadow-sm">
                                        <i class="bi bi-pencil-square"></i> Update
                                    </a>
                                    <a asp-area="Admin" asp-controller="Question" asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger px-3 d-inline-flex align-items-center gap-1 shadow-sm">
                                        <i class="bi bi-trash3"></i> Delete
                                    </a>
                                </div>

                            </div>
                        </div>

                    </div>

                    currentNumber--;
                }
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5 rounded-3 border border-dashed border-secondary-subtle bg-transparent">
                <div class="my-4">
                    <div class="position-relative d-inline-block mb-3">
                        <i class="bi bi-folder-x display-2 text-secondary opacity-25"></i>
                        <span class="position-absolute top-50 start-50 translate-middle-x mt-2 badge rounded-pill bg-primary p-2">
                            <i class="bi bi-question-lg"></i>
                        </span>
                    </div>
                    <h5 class="fw-semibold text-body mb-2">No question & answer data available.</h5>
                    <p class="text-muted small mx-auto" style="max-width: 320px;">
                        Your FAQ list is currently empty. Click the button above to create your first question and answer pair.
                    </p>
                </div>
            </div>
        }
    </div>
</div>