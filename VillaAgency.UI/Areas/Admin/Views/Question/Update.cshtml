@model UpdateQuestionDto
@{
    ViewData["Title"] = "Update Question";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card bg-transparent border-0 shadow-none w-100 m-0 d-flex flex-column" style="min-height: calc(100vh - 180px);">

    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-2 border-bottom border-secondary-subtle px-0 flex-shrink-0">
        <div class="d-flex align-items-center gap-2">
            <span class="bg-primary rounded-pill" style="width: 4px; height: 16px;"></span>
            <h6 class="m-0 fw-bold text-body text-uppercase" style="letter-spacing: 0.5px; font-size: 0.85rem;">
                Update FAQ Item
            </h6>
        </div>
        <a asp-area="Admin" asp-controller="Question" asp-action="Index" class="btn btn-sm btn-outline-secondary px-3 py-1" style="font-size: 0.75rem;">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <div class="card-body px-0 d-flex align-items-center justify-content-center flex-grow-1 py-3">
        <div class="row justify-content-center w-100 m-0">
            <div class="col-12 col-lg-10 col-xl-8">

                <div class="custom-premium-card border border-secondary-subtle rounded-3 shadow-sm overflow-hidden">

                    <form method="post" class="p-4 p-md-5">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label asp-for="QuestionText" class="form-label fw-bold text-body small mb-2 text-uppercase" style="letter-spacing: 0.5px;">
                                <i class="bi bi-question-circle text-primary me-1"></i> Question Text
                            </label>
                            <input asp-for="QuestionText"
                                   class="form-control custom-input shadow-none py-2"
                                   placeholder="Enter the question clearly..." />
                            <span asp-validation-for="QuestionText" class="text-danger small fw-medium mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Answer" class="form-label fw-bold text-body small mb-2 text-uppercase" style="letter-spacing: 0.5px;">
                                <i class="bi bi-chat-left-text text-primary me-1"></i> Detailed Answer
                            </label>
                            <textarea asp-for="Answer" rows="4"
                                      class="form-control custom-input shadow-none py-2"
                                      placeholder="Type the answer here..."></textarea>
                            <span asp-validation-for="Answer" class="text-danger small fw-medium mt-1 d-block"></span>
                        </div>

                        <div class="d-flex align-items-center justify-content-center gap-2 mb-4 p-2 rounded-2 bg-primary bg-opacity-10 border border-primary border-opacity-10 mx-auto" style="font-size: 0.75rem; max-width: 500px;">
                            <i class="bi bi-info-circle-fill text-primary"></i>
                            <span class="text-body-secondary fw-medium">Changes will be updated instantly on the user FAQ page.</span>
                        </div>

                        <div class="d-flex align-items-center justify-content-center gap-3 mt-2">
                            <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow-sm d-flex align-items-center gap-2">
                                <i class="bi bi-check-lg"></i> Save Changes
                            </button>
                            <a asp-area="Admin" asp-controller="Question" asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-semibold">
                                Cancel
                            </a>
                        </div>
                    </form>

                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .custom-premium-card {
        transition: background-color 0.2s ease;
    }

    [data-bs-theme="light"] .custom-premium-card,
    html:not([data-bs-theme="dark"]) .custom-premium-card {
        background-color: #ffffff !important;
    }

    [data-bs-theme="dark"] .custom-premium-card {
        background-color: rgba(255, 255, 255, 0.03) !important;
    }

    .custom-input {
        background-color: rgba(var(--bs-text-color-rgb), 0.03) !important;
        border: 1px solid var(--bs-border-color) !important;
        color: var(--bs-body-color) !important;
        font-size: 0.9rem;
    }

        .custom-input:focus {
            background-color: transparent !important;
            border-color: var(--bs-primary) !important;
            box-shadow: 0 0 0 0.25rem rgba(var(--bs-primary-rgb), 0.05) !important;
        }

        .custom-input::placeholder {
            font-size: 0.85rem;
            opacity: 0.5;
            font-style: italic;
        }
</style>