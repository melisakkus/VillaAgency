@{
    ViewData["Title"] = "Access Denied";
    Layout = null; 
}
<div class="d-flex align-items-center justify-content-center w-100 m-0" style="min-height: 70vh;">
    <div class="text-center p-5 rounded-4 shadow-sm border border-body-tertiary bg-transparent" style="max-width: 500px;">

        <div class="mb-4 d-inline-flex align-items-center justify-content-center bg-danger-subtle text-danger rounded-circle shadow-sm" style="width: 90px; height: 90px;">
            <i class="bi bi-shield-lock-fill" style="font-size: 3.5rem;"></i>
        </div>

        <h1 class="fw-bold text-uppercase tracking-wider text-body mb-2" style="font-size: 1.8rem;">403 - Access Denied</h1>
        <h5 class="fw-semibold text-secondary mb-3">Restricted Access Area</h5>

        <p class="text-muted small mb-4 px-3">
            You do not have the required permissions to view this resource. If you believe this is an error, please reach out to your system administrator.
        </p>

        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-primary px-4 py-2 rounded-3 fw-semibold shadow-sm d-inline-flex align-items-center gap-2">
                <i class="bi bi-speedometer2"></i> Back to Dashboard
            </a>
            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-3 fw-medium">
                Go to Website
            </a>
        </div>

    </div>
</div>