@model List<ResultContactDto>

<link rel="stylesheet" href="~/VillaAgency-1.0.0/assets/css/custom-public-defaultContact.css" />

<div class="contact section" id="contact-us-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 offset-lg-3">
                <div class="section-heading text-center" style="margin-bottom: 50px;">
                    <h6 style="color:#f35525; text-transform: uppercase; font-weight: 700;">| Contact Us</h6>
                    <h2 style="font-size: 34px; font-weight: 700;">Schedule a Private Viewing Today</h2>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="contact-content">
    <div class="container">
        <div class="row">
            <div class="col-lg-7">
                @foreach (var item in Model)
                {
                    <div id="map" class="mb-4">
                        <iframe src="@item.MapUrl" width="100%" height="500px" frameborder="0" style="border:0; border-radius: 20px; box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.05);" allowfullscreen=""></iframe>
                    </div>

                    <div class="row">
                        <div class="col-lg-6 mb-4">
                            <a href="tel:@item.PhoneNumber" class="custom-contact-card">
                                <div class="contact-card-icon">
                                    <img src="~/VillaAgency-1.0.0/assets/images/phone-icon.png" alt="Phone">
                                </div>
                                <div class="contact-card-info">
                                    <h5>
                                        @if (!string.IsNullOrEmpty(item.PhoneNumber))
                                        {
                                            var rawNumber = item.PhoneNumber;
                                            string displayNumber = rawNumber;
                                            if (rawNumber.StartsWith("+1") && rawNumber.Length == 12)
                                            {
                                                displayNumber =
                                                $"+1 ({rawNumber.Substring(2, 3)}) {rawNumber.Substring(5, 3)}-{rawNumber.Substring(8, 4)}";
                                            }
                                            @displayNumber
                                        }
                                        else
                                        {
                                            @:No number provided
                                        }
                                    </h5>
                                    <span>Phone Number</span>
                                </div>
                            </a>
                        </div>

                        <div class="col-lg-6 mb-4">
                            <a href="mailto:@item.Email" class="custom-contact-card">
                                <div class="contact-card-icon">
                                    <img src="~/VillaAgency-1.0.0/assets/images/email-icon.png" alt="Email">
                                </div>
                                <div class="contact-card-info">
                                    <h5 class="text-truncate" title="@item.Email">@item.Email</h5>
                                    <span>Business Email</span>
                                </div>
                            </a>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-5 ps-lg-4" style="padding-left:0;">
                <div class="form-column-wrapper">
                    <div class="contact-form-container">
                        <form id="contact-form" asp-controller="Default" asp-action="SendMessage" method="post">
                            <div class="row">
                                <div class="col-lg-12">
                                    <fieldset>
                                        <label for="name">Full Name</label>
                                        <input type="text" name="Name" id="name" placeholder="Your Name...">
                                        <span class="validation-error error-Name"></span>
                                    </fieldset>
                                </div>
                                <div class="col-lg-12">
                                    <fieldset>
                                        <label for="email">Email Address</label>
                                        <input type="text" name="Email" id="email" placeholder="Your E-mail...">
                                        <span class="validation-error error-Email"></span>
                                    </fieldset>
                                </div>
                                <div class="col-lg-12">
                                    <fieldset>
                                        <label for="subject">Subject</label>
                                        <input type="text" name="Subject" id="subject" placeholder="Subject...">
                                        <span class="validation-error error-Subject"></span>
                                    </fieldset>
                                </div>
                                <div class="col-lg-12">
                                    <fieldset>
                                        <label for="message">Message</label>
                                        <textarea name="Content"
                                                  id="message"
                                                  rows="4"
                                                  placeholder="Your Message..."></textarea>
                                        <span class="validation-error error-Content"></span>
                                    </fieldset>
                                </div>
                                <div class="col-lg-12">
                                    <fieldset style="margin-bottom: 0;">
                                        <button type="submit" id="form-submit">Send Message</button>
                                    </fieldset>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/VillaAgency-1.0.0/assets/js/custom-public-defaultContact.js"></script>