@model List<ResultProductDto>

<style>

    .fun-facts {
        margin-bottom: 60px;
    }

        .fun-facts .fact-item {
            background-color: #fafafa;
            border-radius: 10px;
            padding: 25px 30px;
            position: relative;
            display: flex;
            align-items: center;
            gap: 15px;
            box-shadow: 0px 0px 15px rgba(0,0,0,0.03);
        }

            .fun-facts .fact-item h2 {
                color: #f35525;
                font-size: 36px;
                font-weight: 800;
                margin: 0;
                line-height: 1;
            }

            .fun-facts .fact-item p {
                color: #1e1e1e;
                font-size: 15px;
                font-weight: 600;
                margin: 0;
                line-height: 1.3;
            }

            .fun-facts .fact-item::after {
                content: '';
                position: absolute;
                width: 30px;
                height: 30px;
                background-color: #f35525;
                border-radius: 50%;
                right: -15px;
                top: -15px;
                opacity: 0.85;
            }


    .best-deal {
        padding: 90px 0px;
    }

        .best-deal .section-heading h2 {
            font-size: 40px;
            font-weight: 800;
            line-height: 50px;
            margin-top: 15px;
        }

        .best-deal .nav-tabs {
            border-bottom: none;
            gap: 15px;
        }

        .best-deal .nav-link {
            background-color: #1e1e1e !important;
            color: #fff !important;
            border: none !important;
            border-radius: 5px !important;
            padding: 12px 28px !important;
            font-weight: 600;
            font-size: 15px;
            transition: all 0.3s ease;
        }

            .best-deal .nav-link.active {
                background-color: #f35525 !important;
                color: #fff !important;
            }


        .best-deal .info-table {
            background-color: #fff;
            box-shadow: 0px 0px 15px rgba(0, 0, 0, 0.08);
            padding: 25px 25px;
            border-radius: 10px;
            width: 100%;
        }

            .best-deal .info-table ul {
                list-style: none;
                padding: 0;
                margin: 0;
            }

                .best-deal .info-table ul li {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    padding: 14px 0;
                    border-bottom: 1px solid #f5f5f5;
                    color: #aaa;
                    font-size: 14px;
                    font-weight: 500;
                }

                    .best-deal .info-table ul li:last-child {
                        border-bottom: none;
                    }

                    .best-deal .info-table ul li span {
                        font-weight: 700;
                        color: #1e1e1e;
                        font-size: 16px;
                    }

                        .best-deal .info-table ul li span.area-highlight {
                            color: #f35525;
                            font-weight: 800;
                        }

        .best-deal h4 {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 25px;
            color: #1e1e1e;
        }

        .best-deal p {
            color: #4a4a4a;
            line-height: 1.8;
            font-size: 14px;
            margin-bottom: 25px;
        }

        .best-deal .main-button a {
            display: inline-block;
            background-color: #1e1e1e;
            color: #fff;
            font-size: 14px;
            font-weight: 500;
            padding: 12px 25px;
            border-radius: 25px;
            text-decoration: none;
            transition: all 0.3s;
        }

            .best-deal .main-button a:hover {
                background-color: #f35525;
            }
</style>

@{
    var firstCategory = Enumerable.FirstOrDefault(ViewBag.Categories as IEnumerable<string>);
    var activeCategorySlug = firstCategory != null ? firstCategory.Replace(" ", "").ToLower() : "";
}

<div class="section best-deal">
    <div class="container">
        <div class="row align-items-end mb-5">
            <div class="col-lg-6">
                <div class="section-heading">
                    <h6 style="color: #f35525; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">| Best Deal</h6>
                    <h2>Premium Properties with Exceptional Value</h2>
                </div>
            </div>
            <div class="col-lg-6 text-lg-end text-start mt-4 mt-lg-0">
                <ul class="nav nav-tabs justify-content-lg-end justify-content-start" role="tablist">
                    @foreach (var category in ViewBag.Categories)
                    {
                        var cleanedCategoryTarget = category.Replace(" ", "").ToLower();
                        var isFirst = cleanedCategoryTarget == activeCategorySlug;

                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(isFirst ? "active" : "")"
                                    id="@(cleanedCategoryTarget)-tab"
                                    data-bs-toggle="tab"
                                    data-bs-target="#@(cleanedCategoryTarget)"
                                    type="button"
                                    role="tab"
                                    aria-controls="@cleanedCategoryTarget"
                                    aria-selected="@(isFirst ? "true" : "false")">
                                @category
                            </button>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <div class="tab-content" id="myTabContent">
                    @foreach (var item in Model)
                    {
                        var cleanedItemCategory = item.Category.Replace(" ", "").ToLower();
                        var isFirstContent = cleanedItemCategory == activeCategorySlug;

                        <div class="tab-pane fade @(isFirstContent ? "show active" : "")"
                             id="@(cleanedItemCategory)"
                             role="tabpanel"
                             aria-labelledby="@(cleanedItemCategory)-tab">
                            <div class="row align-items-center">

                                <div class="col-lg-3 mb-4 mb-lg-0">
                                    <div class="info-table">
                                        <ul>
                                            @if (item.Area != null)
                                            {
                                                <li>Total Flat Space <span>@item.Area m²</span></li>
                                            }
                                            @if (item.Floor != null)
                                            {
                                                <li>Floor number <span>@item.Floor</span></li>
                                            }
                                            @if (item.BedroomCount != null)
                                            {
                                                <li>Number of rooms <span>@item.BedroomCount</span></li>
                                            }
                                            @if (item.BathroomCount != null)
                                            {
                                                <li>Number of bathrooms <span>@item.BathroomCount</span></li>
                                            }
                                            @if (item.ParkingCount != null)
                                            {
                                                <li>Parking count <span>@item.ParkingCount</span></li>
                                            }
                                        </ul>
                                    </div>
                                </div>

                                <div class="col-lg-6 mb-4 mb-lg-0 text-center">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl"
                                             alt="@item.Title"
                                             class="img-fluid rounded shadow-sm"
                                             style="max-height: 400px; width: 100%; object-fit: cover;"
                                             onerror="this.onerror=null; this.src='https://images.pexels.com/photos/8469937/pexels-photo-8469937.jpeg?_gl=1*1n3bc7a*_ga*MTU1NjgzNzg5OS4xNzgzMzMzMTkw*_ga_8JE65Q40S6*czE3ODMzNDYwNTEkbzMkZzEkdDE3ODMzNDY1NDUkajUxJGwwJGgw';">
                                    }
                                    else
                                    {
                                        <img src="https://images.pexels.com/photos/8469937/pexels-photo-8469937.jpeg?_gl=1*1n3bc7a*_ga*MTU1NjgzNzg5OS4xNzgzMzMzMTkw*_ga_8JE65Q40S6*czE3ODMzNDYwNTEkbzMkZzEkdDE3ODMzNDY1NDUkajUxJGwwJGgw"
                                             alt="Default Property Image"
                                             class="img-fluid rounded shadow-sm"
                                             style="max-height: 400px; width: 100%; object-fit: cover;">
                                    }
                                </div>

                                <div class="col-lg-3">
                                    <h4>@item.Title</h4>
                                    <p>
                                        Welcome to your next chapter of refined living. This carefully curated property combines contemporary architectural design with functional spaces, ensuring ultimate privacy and convenience.
                                    </p>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>