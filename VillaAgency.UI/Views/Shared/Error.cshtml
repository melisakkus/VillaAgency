@model ErrorViewModel
@{
    ViewData["Title"] = "Oops! Something went wrong";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .error-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 70vh;
            text-align: center;
        }

            .error-container img {
                max-width: 400px;
                margin-bottom: 2rem;
            }

            .error-container h1 {
                font-size: 4rem;
                font-weight: bold;
                color: #333;
            }

            .error-container span {
                color: #dc3545;
            }

        .btn-custom {
            padding: 12px 30px;
            font-weight: 600;
            border-radius: 50px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

            .btn-custom:hover {
                transform: translateY(-3px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }
    </style>
</head>
<body>

    <div class="container error-container">
        <img src="https://i.imgur.com/qIufhof.png" alt="Error Illustration" />

        <h1>
            <span>500</span> <br />
            Internal Server Error
        </h1>

        <p class="lead">@Model.UserMessage</p>

        <div class="mt-4">
            @{
                string redirectUrl;
                string buttonText;

                if (User.Identity.IsAuthenticated)
                {
                    redirectUrl = Url.Action("Index", "Dashboard", new { area = "Admin" });
                    buttonText = "Back to Dashboard";
                }
                else
                {
                    redirectUrl = Url.Action("Index", "Default");
                    buttonText = "Back to Home";
                }
            }

            <a href="@redirectUrl" class="btn btn-primary btn-custom btn-lg">
                @buttonText
            </a>
        </div>

        @if (Model.ShowRequestId)
        {
            <p class="mt-4 text-muted small">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </p>
        }

        <p class="info mt-5 text-muted small">
            Illustration taken from
            <a href="https://www.kapwing.com/404-illustrations" target="_blank">kapwing.com</a>
        </p>
    </div>

    @if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
    {
        <div class="container mt-5">
            <div class="alert alert-warning">
                <h3 class="alert-heading">Development Mode</h3>
                <p>Detailed error information is only visible in the development environment.</p>
                <code>@Model.RequestId</code>
            </div>
        </div>
    }

</body>
</html>